# ============================================================
# HopeFusion Africa — Environment Variables Reference
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── APP ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://hopefusionafrica.com

# ── DATABASE (Supabase) ────────────────────────────────────────
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── REDIS (Upstash) ───────────────────────────────────────────
REDIS_URL=rediss://default:TOKEN@HOSTNAME.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── AI (Anthropic Claude) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── PAYMENTS ──────────────────────────────────────────────────
# Paystack
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# MTN Mobile Money
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_API_USER=your_mtn_api_user_uuid
MTN_MOMO_API_KEY=your_mtn_api_key

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE_...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE_...
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_secret

# ── PUSH NOTIFICATIONS ────────────────────────────────────────
# Generate with: node -e "import('web-push').then(wp => { const k = wp.default.generateVAPIDKeys(); console.log(k); })"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hopefusionafrica.com

# Firebase (optional — for FCM mobile push)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── EMAIL (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@hopefusionafrica.com
SMTP_PASS=your_app_password
SMTP_FROM=info@hopefusionafrica.com

# ── FILE STORAGE (Cloudinary) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OAUTH ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
