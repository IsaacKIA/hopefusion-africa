# ============================================================
# HopeFusion Africa — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── APP ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
AI_ENGINE_PORT=3001
FRONTEND_URL=http://localhost:5500

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://hopefusion:yourpassword@localhost:5432/hopefusion_db

# ── REDIS ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── ANTHROPIC (Claude AI) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PAYSTACK ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
PAYSTACK_STARTUP_PRO_PLAN=PLN_...
PAYSTACK_INVESTOR_PRO_PLAN=PLN_...

# ── MTN MOBILE MONEY ─────────────────────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_API_USER=your_mtn_api_user_uuid
MTN_MOMO_API_KEY=your_mtn_api_key

# ── FLUTTERWAVE ──────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE_...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE_...
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_secret

# ── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@hopefusionafrica.com
SMTP_PASS=your_app_password
SMTP_FROM=info@hopefusionafrica.com

# ── FILE STORAGE (Cloudinary) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=hopefusion
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OAUTH ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
