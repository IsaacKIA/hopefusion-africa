{
  "name": "hopefusion-africa",
  "version": "1.0.0",
  "description": "HopeFusion Africa — AI-powered startup ecosystem platform",
  "type": "module",
  "scripts": {
    "dev": "nodemon --experimental-specifier-resolution=node src/server.js",
    "start": "node --experimental-specifier-resolution=node src/server.js",
    "db:migrate": "node --experimental-specifier-resolution=node src/scripts/setup-db.js",
    "db:seed": "node --experimental-specifier-resolution=node src/scripts/seed.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --detectOpenHandles",
    "lint": "eslint src/ --ext .js,.jsx",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix",
    "type-check": "echo 'Backend is JavaScript (no type checking required)'",
    "health": "curl -s http://localhost:3000/api/v1/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.5",
    "redis": "^4.7.1",
    "resend": "^6.12.4",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
